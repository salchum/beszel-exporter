BESZEL_EMAIL=you@example.com
BESZEL_PASSWORD=your-password

# Optional TLS settings for HTTPS Beszel hubs with private/self-signed certificates.
# Prefer BESZEL_CA_FILE when you have the CA certificate.
# BESZEL_CA_FILE=/path/to/ca.pem

# Use only for trusted internal networks.
# BESZEL_INSECURE_SKIP_TLS_VERIFY=false
